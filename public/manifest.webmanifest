{
  "name": "CHROMALUM",
  "short_name": "CHROMALUM",
  "description": "CHROMALUM is a browser-based color playground for drawing grayscale pixel art, mapping it to palettes, testing glaze overlays, exploring visual patterns, and experimenting with color-based music.",
