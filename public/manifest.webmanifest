  "scope": "./",
  "display": "standalone",
  "orientation": "any",
  "theme_color": "#0a0a12",
  "background_color": "#0a0a12",
  "lang": "en",
  "icons": [
    {
      "src": "favicon.svg",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "any"
    },
    {
      "src": "icon-maskable.svg",
      "type": "image/svg+xml",
      "sizes": "any",
      "purpose": "maskable"
    }
  ]
}
